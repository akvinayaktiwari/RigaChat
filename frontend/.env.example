# Backend API URL
VITE_API_URL=

# Voice agent WebSocket URL (API Gateway WebSocket API, used by voice-widget.js)
VITE_VOICE_WS_URL=

# Cognito configuration
VITE_COGNITO_DOMAIN=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REDIRECT_URI=
VITE_COGNITO_REGION=

# CDN URL for widget
VITE_CDN_URL=

# Staff Cognito pool configuration (internal ops console, /admin/*) — pool ID
# isn't needed client-side for raw InitiateAuth calls, only client_id/region
VITE_STAFF_COGNITO_CLIENT_ID=
VITE_STAFF_COGNITO_REGION=
