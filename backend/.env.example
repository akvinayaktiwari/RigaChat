# OpenAI API key used for embeddings (text-embedding-3-small) and chat completions (gpt-4o-mini)
OPENAI_API_KEY=

# Pinecone API key used for vector storage/retrieval of RAG embeddings
PINECONE_API_KEY=

# Name of the Pinecone index used for RAG embeddings
PINECONE_INDEX_NAME=

# AWS region for DynamoDB, Cognito, and Lambda resources
AWS_REGION=

# DynamoDB table name for clients (partition key: clientId)
DYNAMODB_TABLE_CLIENTS=

# DynamoDB table name for bots (partition key: clientId, sort key: botId)
DYNAMODB_TABLE_BOTS=

# DynamoDB table name for leads (partition key: botId, sort key: createdAt)
DYNAMODB_TABLE_LEADS=

# DynamoDB table name for conversations (partition key: botId, sort key: conversationId)
DYNAMODB_TABLE_CONVERSATIONS=

# DynamoDB table name for knowledge base entries (partition key: botId, sort key: entryId)
DYNAMODB_TABLE_KB=

# DynamoDB table name for forms (partition key: clientId, sort key: formId, GSI: formId-index)
DYNAMODB_TABLE_FORMS=

# DynamoDB table name for form leads (partition key: formId, sort key: leadId, GSIs: clientId-index, leadId-index)
DYNAMODB_TABLE_FORM_LEADS=

DYNAMODB_TABLE_VOICE_AGENTS=

# DynamoDB table name for voice call logs (partition key: agentId, sort key: callId)
DYNAMODB_TABLE_VOICE_CALL_LOGS=

# Zoho CRM OAuth app client ID (Zoho API Console, self-client or server-based app)
ZOHO_CLIENT_ID=

# Zoho CRM OAuth app client secret
ZOHO_CLIENT_SECRET=

# Redirect URI registered with the Zoho OAuth app, must match
# {BACKEND_URL}/api/integrations/zoho/callback
ZOHO_REDIRECT_URI=

# AWS Cognito User Pool ID used to verify JWTs on protected routes
COGNITO_USER_POOL_ID=

# AWS Cognito App Client ID used to verify JWTs on protected routes
COGNITO_CLIENT_ID=bia5g9e6gsb3h9n191rcvkugn

# URL of the deployed frontend, used for CORS configuration
FRONTEND_URL=

# Name of the main (buffered) AWS Lambda function to deploy to (used by the deploy script)
LAMBDA_FUNCTION_NAME=

# Name of the streaming AWS Lambda function (RESPONSE_STREAM mode) that handles
# /api/chat/message, deployed from the same build (used by the deploy script)
LAMBDA_STREAMING_FUNCTION_NAME=

# Port for the local dev server (defaults to 3000 if unset)
PORT=

# Node environment (development | production); local dev server only starts when not 'production'
NODE_ENV=


SQS_CRAWLER_QUEUE_URL=
