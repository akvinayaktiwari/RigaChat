{
  "name": "beepboop-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "TS_NODE_TRANSPILE_ONLY=true nodemon --watch src --watch index.ts --ext ts --exec \"node --env-file=.env --loader ts-node/esm\" index.ts",
    "build": "tsc --noEmit && esbuild index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js && echo '{\"type\":\"commonjs\"}' > dist/package.json",
    "build:relay": "npx esbuild src/voice-relay/server.ts --bundle --platform=node --format=cjs --outfile=dist/voice-relay.js --external:@aws-sdk/*",
    "deploy": "npm run build && node scripts/deploy.js"
  },
  "dependencies": {
    "@aws-sdk/client-apigatewaymanagementapi": "^3.1087.0",
    "@aws-sdk/client-cognito-identity-provider": "^3.1083.0",
    "@aws-sdk/client-dynamodb": "^3.658.0",
    "@aws-sdk/client-kms": "^3.1084.0",
    "@aws-sdk/client-s3": "^3.1091.0",
    "@aws-sdk/client-sqs": "^3.1085.0",
    "@aws-sdk/lib-dynamodb": "^3.658.0",
    "@aws-sdk/s3-request-presigner": "^3.1091.0",
    "@hono/node-server": "^1.13.0",
    "@pinecone-database/pinecone": "^3.0.3",
    "@upstash/redis": "^1.38.0",
    "aws-jwt-verify": "^4.0.1",
    "cheerio": "^1.0.0",
    "dotenv": "^16.4.5",
    "fast-xml-parser": "^5.10.0",
    "hono": "^4.6.0",
    "mammoth": "^1.12.0",
    "node-fetch": "^3.3.2",
    "openai": "^4.63.0",
    "razorpay": "^2.9.8",
    "unpdf": "^1.6.2",
    "uuid": "^9.0.1",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/aws-lambda": "^8.10.162",
    "@types/node": "^20.16.5",
    "@types/uuid": "^9.0.8",
    "@types/ws": "^8.5.12",
    "esbuild": "^0.23.1",
    "nodemon": "^3.1.4",
    "ts-node": "^10.9.2",
    "typescript": "^5.6.2"
  }
}
