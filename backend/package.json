{
  "name": "rigachat-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon --watch src --watch index.ts --ext ts --exec \"node --loader ts-node/esm\" index.ts",
    "build": "tsc --noEmit && esbuild index.ts --bundle --platform=node --target=node20 --outfile=dist/index.js",
    "deploy": "cd dist && zip -r ../function.zip index.js && cd .. && aws lambda update-function-code --function-name \"$LAMBDA_FUNCTION_NAME\" --zip-file fileb://function.zip"
  },
  "dependencies": {
    "hono": "^4.6.0",
    "@hono/node-server": "^1.13.0",
    "@aws-sdk/client-dynamodb": "^3.658.0",
    "@aws-sdk/lib-dynamodb": "^3.658.0",
    "openai": "^4.63.0",
    "@pinecone-database/pinecone": "^3.0.3",
    "aws-jwt-verify": "^4.0.1",
    "dotenv": "^16.4.5",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "typescript": "^5.6.2",
    "@types/node": "^20.16.5",
    "@types/uuid": "^9.0.8",
    "ts-node": "^10.9.2",
    "nodemon": "^3.1.4",
    "esbuild": "^0.23.1"
  }
}
